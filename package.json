{
  "name": "birthday-reminder",
  "version": "1.0.0",
  "description": "Birthday reminder app with cron and email notifications",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:install": "cd client && npm install",
    "build": "npm run client:build",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && npm run client:install"
  },
  "keywords": ["node", "express", "react", "cron", "email", "mvc"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.0.0",
    "nodemailer": "^6.9.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}